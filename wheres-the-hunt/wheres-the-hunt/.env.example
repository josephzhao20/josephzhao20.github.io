# Supabase project settings (https://app.supabase.com/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server-only, NEVER expose to the client.
# Used for admin actions (approving uploaders, featuring adventures, etc.)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public site URL, used for auth redirects
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Nominatim (OpenStreetMap) geocoding — no key required, but set a contact
# email per Nominatim's usage policy: https://operations.osmfoundation.org/policies/nominatim/
NOMINATIM_CONTACT_EMAIL=you@example.com
