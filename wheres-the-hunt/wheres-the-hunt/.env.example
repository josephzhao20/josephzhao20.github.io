# Supabase project settings (https://app.supabase.com/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Public site URL, used for auth redirects and sitemap
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# Nominatim (OpenStreetMap) geocoding — set a contact email per usage policy
NOMINATIM_CONTACT_EMAIL=your-email@example.com

# Admin email for notifications
ADMIN_EMAIL=your-admin@example.com

# Shopify Storefront API — https://shopify.dev/docs/api/storefront
# Get this from the Buy Button app embed code (storefrontAccessToken field)
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=your_storefront_access_token

# Zapier webhook for new user signup notifications (optional)
ZAPIER_NEW_USER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/your_hook
