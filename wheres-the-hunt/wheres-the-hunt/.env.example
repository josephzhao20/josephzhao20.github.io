# Supabase project settings (https://app.supabase.com/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Public site URL, used for auth redirects
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# Nominatim (OpenStreetMap) geocoding — set a contact email per usage policy
NOMINATIM_CONTACT_EMAIL=your-email@example.com

# Resend (email sending) — https://resend.com
RESEND_API_KEY=re_your_resend_api_key

# Shopify Storefront API — https://shopify.dev/docs/api/storefront
# Create a token in Shopify Admin -> Settings -> Apps -> your app -> API credentials
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=more-2-the-hunt.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=paste_your_token_here

# Admin email for notifications
ADMIN_EMAIL=your-admin@example.com
